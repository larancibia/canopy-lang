# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-api-key-here
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://canopy:canopy_dev_password@localhost:5432/canopy
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# Data Providers
YAHOO_FINANCE_ENABLED=true
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpha Vantage (optional)
ALPHA_VANTAGE_API_KEY=

# IEX Cloud (optional)
IEX_CLOUD_API_KEY=
IEX_CLOUD_SANDBOX=true

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Security
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Backtest Configuration
MAX_BACKTEST_DURATION_DAYS=3650
DEFAULT_INITIAL_CAPITAL=10000
DEFAULT_COMMISSION=0.001

# Job Queue
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@canopy-lang.com
